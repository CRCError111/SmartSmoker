{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["transfer_id", "program_id", "program_name", "stages"],
  "properties": {
    "transfer_id": {
      "type": "string",
      "pattern": "^tr_[0-9]{8}_[0-9]{6}_[a-z0-9]+$"
    },
    "program_id": {
      "type": "integer",
      "minimum": 1
    },
    "program_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "category": {
      "type": "string",
      "enum": ["fish", "meat", "poultry", "cheese", "vegetables", "other"]
    },
    "estimated_duration": {
      "type": "integer",
      "minimum": 1
    },
    "target_product": {
      "type": "string",
      "maxLength": 255
    },
    "wood_type": {
      "type": "string",
      "maxLength": 255
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/stage"
      }
    }
  },
  "definitions": {
    "stage": {
      "type": "object",
      "required": ["stage_order", "stage_name", "target_temp", "duration_minutes"],
      "properties": {
        "stage_order": {
          "type": "integer",
          "minimum": 1
        },
        "stage_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "target_temp": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "target_humidity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "use_smoke_generator": {
          "type": "boolean"
        },
        "smoke_intensity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "ventilation_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "internal_fan_on": {
          "type": "boolean"
        },
        "injection_fan_on": {
          "type": "boolean"
        },
        "compressor_pwm": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  }
}
